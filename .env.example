"""
╔══════════════════════════════════════════════════════════╗
║       🎬  AI Viral Storyteller — Complete System        ║
║                                                          ║
║   Topic  →  Script  →  Pixar Video  →  Social Upload    ║
║                                                          ║
║   Engine: Claude + fal.ai + upload-post.com             ║
╚══════════════════════════════════════════════════════════╝

Setup:
    pip install anthropic httpx python-dotenv upload-post

.env file mein 3 keys chahiye:
    FAL_AI_KEY=...            https://fal.ai/dashboard/keys
    ANTHROPIC_API_KEY=...     https://console.anthropic.com/
    UPLOAD_POST_API_KEY=...   https://upload-post.com/dashboard  (optional)
    UPLOAD_POST_PROFILE=...   upload-post account profile name

Run:
    python storyteller.py
    python storyteller.py --topic "Ek yateem bachay ki kahani" --category "Emotional / Dil"
"""

import asyncio
import argparse
import json
import os
import re
import sys
import time
from datetime import datetime
from pathlib import Path

try:
    from dotenv import load_dotenv
    load_dotenv()
except ImportError:
    pass

try:
    import httpx
except ImportError:
    print("❌  httpx install nahi. Run karo: pip install httpx")
    sys.exit(1)

try:
    import anthropic
except ImportError:
    print("❌  anthropic install nahi. Run karo: pip install anthropic")
    sys.exit(1)


# ═══════════════════════════════════════════════════════════════════════════════
#  CONSTANTS
# ═══════════════════════════════════════════════════════════════════════════════

OUTPUT_DIR = Path("output")
OUTPUT_DIR.mkdir(exist_ok=True)

CATEGORIES = [
    "Islamic / Deen",
    "Motivational",
    "Education / Taleem",
    "Funny / Mazaak",
    "Emotional / Dil",
    "Lifestyle",
]

PLATFORM_OPTIONS = {
    "1": ["youtube", "tiktok", "instagram"],
    "2": ["youtube"],
    "3": ["tiktok", "instagram"],
    "4": ["tiktok"],
    "5": ["youtube", "instagram"],
}

MUSIC_MOODS = {
    "Islamic / Deen":     "calm peaceful nasheed-style instrumental, oud and strings, no lyrics, reverent",
    "Motivational":       "epic cinematic orchestral, building swell, inspiring, no lyrics",
    "Education / Taleem": "gentle curious piano, warm and hopeful background music, no lyrics",
    "Funny / Mazaak":     "playful comedic xylophone and ukulele, upbeat cartoonish sound, no lyrics",
    "Emotional / Dil":    "soft emotional strings with piano, heartfelt melancholic tone, no lyrics",
    "Lifestyle":          "warm cozy acoustic guitar, feel-good light percussion, no lyrics",
}

PIXAR_STYLE = (
    ", 3D Pixar CGI animation quality, cinematic subsurface scattering, "
    "ray traced lighting, ultra detailed 8K render, vibrant saturated colors, "
    "soft dramatic shadows, Disney Pixar studio quality, 9:16 vertical format"
)

CLAUDE_SYSTEM_PROMPT = """You are an expert viral YouTube Shorts story creator for Pakistani Urdu-speaking audiences.
You create emotionally gripping, culturally authentic short stories animated in 3D Pixar style.

IMPORTANT: Respond with VALID JSON ONLY. No markdown. No explanation. Nothing before or after JSON.

Return exactly this JSON structure:
{
  "title": "Urdu title max 60 chars, emotional hook that makes people click",
  "description": "YouTube description in Urdu 80 words, end with 3 hashtags like #viral #urdu #pakistan",
  "tags": ["tag1","tag2","tag3","tag4","tag5","tag6","tag7","tag8","tag9","tag10"],
  "thumbnail_prompt": "3D Pixar CGI render, [English prompt for thumbnail showing peak emotional moment]",
  "scenes": [
    {
      "index": 1,
      "image_prompt": "3D Pixar CGI render, [English: character, setting, lighting, mood, camera angle]",
      "narration_urdu": "Urdu narration 20-30 words, emotional and gripping",
      "narration_english": "English translation for lip sync",
      "animation_prompt": "English: camera movement, character expression, body motion for this 5-second clip",
      "duration": 5
    }
  ],
  "outro_urdu": "Subscribe karo aur like zaroor karo!",
  "outro_english": "Please subscribe and like!"
}

RULES:
- Exactly 6 scenes, story arc: hook > conflict > climax > resolution
- All image_prompt and animation_prompt in English only
- All narration_urdu in Urdu script
- Pakistani settings: ghar, masjid, school, bazaar, village, hospital
- Same character must appear consistently across all 6 scenes
- Exactly 10 tags mixing English and Roman Urdu
- Every image_prompt MUST start with: 3D Pixar CGI render,
"""

# fal.ai endpoints
FAL_FLUX_SUBMIT      = "https://queue.fal.run/fal-ai/flux-pro/v1.1-ultra"
FAL_FLUX_STATUS      = "https://queue.fal.run/fal-ai/flux-pro/v1.1-ultra/requests/{req_id}"
FAL_KLING_SUBMIT     = "https://queue.fal.run/fal-ai/kling-video/v2.6/pro/image-to-video"
FAL_KLING_STATUS     = "https://queue.fal.run/fal-ai/kling-video/v2.6/pro/image-to-video/requests/{req_id}"
FAL_MUSIC_SUBMIT     = "https://queue.fal.run/fal-ai/minimax-music"
FAL_MUSIC_STATUS     = "https://queue.fal.run/fal-ai/minimax-music/requests/{req_id}"
FAL_MERGE_VID_SUBMIT = "https://queue.fal.run/fal-ai/ffmpeg-api/merge-videos"
FAL_MERGE_VID_STATUS = "https://queue.fal.run/fal-ai/ffmpeg-api/merge-videos/requests/{req_id}"
FAL_MERGE_AUD_SUBMIT = "https://queue.fal.run/fal-ai/ffmpeg-api/merge-audio-video"
FAL_MERGE_AUD_STATUS = "https://queue.fal.run/fal-ai/ffmpeg-api/merge-audio-video/requests/{req_id}"


# ═══════════════════════════════════════════════════════════════════════════════
#  FAL.AI CLIENT  (ek key se sab models chalte hain)
# ═══════════════════════════════════════════════════════════════════════════════

def fal_headers():
    key = os.environ.get("FAL_AI_KEY", "")
    if not key:
        raise EnvironmentError(
            "\n❌  FAL_AI_KEY set nahi hai!\n"
            "   .env mein likho: FAL_AI_KEY=your_key\n"
            "   Key yahan se lein: https://fal.ai/dashboard/keys\n"
        )
    return {"Authorization": f"Key {key}", "Content-Type": "application/json"}


async def fal_submit(endpoint: str, payload: dict) -> str:
    """fal.ai queue pe job bhejo, request_id wapis milega"""
    async with httpx.AsyncClient(timeout=60) as client:
        resp = await client.post(endpoint, json=payload, headers=fal_headers())
        resp.raise_for_status()
        data = resp.json()
    req_id = data.get("request_id") or data.get("id") or ""
    if not req_id:
        raise ValueError(f"fal.ai ne request_id nahi diya. Response: {data}")
    print(f"        Job submit hua → {req_id[:28]}...")
    return req_id


async def fal_wait(status_url: str, label: str = "job", max_sec: int = 300) -> dict:
    """Har 6 second mein status check karo jab tak COMPLETED na ho"""
    elapsed = 0
    async with httpx.AsyncClient(timeout=30) as client:
        while elapsed < max_sec:
            await asyncio.sleep(6)
            elapsed += 6
            resp = await client.get(status_url, headers=fal_headers())
            resp.raise_for_status()
            data = resp.json()
            status = str(data.get("status") or data.get("state") or "UNKNOWN").upper()
            print(f"        [{label}] {status} — {elapsed}s")
            if status in ("COMPLETED", "SUCCEEDED", "SUCCESS"):
                return data.get("output") or data.get("result") or data
            if status in ("FAILED", "ERROR", "CANCELLED"):
                raise RuntimeError(f"fal.ai job fail [{label}]: {data.get('error') or data}")
    raise TimeoutError(f"fal.ai [{label}] {max_sec}s mein complete nahi hua")


# ═══════════════════════════════════════════════════════════════════════════════
#  STEP 1 — SCRIPT WRITER (Claude)
# ═══════════════════════════════════════════════════════════════════════════════

def generate_script(topic: str, category: str) -> dict:
    """Claude se Urdu story script banao"""
    api_key = os.environ.get("ANTHROPIC_API_KEY", "")
    if not api_key:
        raise EnvironmentError(
            "\n❌  ANTHROPIC_API_KEY set nahi hai!\n"
            "   Key: https://console.anthropic.com/\n"
        )

    client = anthropic.Anthropic(api_key=api_key)
    music_mood = MUSIC_MOODS.get(category, MUSIC_MOODS["Motivational"])

    user_msg = (
        f"Topic: {topic}\n"
        f"Category: {category}\n"
        f"Music mood: {music_mood}\n"
        f"Style: 3D Pixar CGI animation, Pakistani cultural context\n\n"
        "Emotionally gripping story. Hook in first 3 seconds. Satisfying ending.\n"
        "Respond with JSON only."
    )

    print("    Claude se script manga raha hoon...")
    response = client.messages.create(
        model="claude-sonnet-4-20250514",
        max_tokens=4000,
        system=CLAUDE_SYSTEM_PROMPT,
        messages=[{"role": "user", "content": user_msg}],
    )

    raw = response.content[0].text.strip()
    raw = re.sub(r"^```json\s*", "", raw, flags=re.MULTILINE)
    raw = re.sub(r"^```\s*",     "", raw, flags=re.MULTILINE)
    raw = raw.strip()

    script = json.loads(raw)

    scenes = script.get("scenes", [])
    if len(scenes) != 6:
        raise ValueError(f"Claude ne {len(scenes)} scenes diye, 6 chahiye. Dobara run karo.")

    # Pixar style suffix har scene mein add karo
    for scene in scenes:
        img = scene.get("image_prompt", "")
        if not img.startswith("3D Pixar CGI render,"):
            img = "3D Pixar CGI render, " + img
        scene["image_prompt"] = img + PIXAR_STYLE
        scene["animation_prompt"] = (
            scene.get("animation_prompt", "") +
            ", smooth fluid Pixar-style motion, 24fps cinematic camera"
        )

    # Thumbnail bhi
    thumb = script.get("thumbnail_prompt", f"3D Pixar CGI render, {topic}")
    if not thumb.startswith("3D Pixar CGI render,"):
        thumb = "3D Pixar CGI render, " + thumb
    script["thumbnail_prompt"] = thumb + PIXAR_STYLE

    script["music_mood"] = music_mood
    script["category"]   = category
    script["topic"]      = topic

    print(f"    Script tayar: \"{script['title']}\"")
    return script


# ═══════════════════════════════════════════════════════════════════════════════
#  STEP 2 — IMAGE GENERATOR (FLUX Pro via fal.ai)
# ═══════════════════════════════════════════════════════════════════════════════

async def make_one_image(image_prompt: str, scene_index: int) -> str:
    """Ek scene ka 3D Pixar image banao, URL return karo"""
    print(f"    [Image] Scene {scene_index}: FLUX Pro pe bhej raha hoon...")

    payload = {
        "prompt":                image_prompt,
        "image_size":            "portrait_16_9",
        "num_inference_steps":   35,
        "guidance_scale":        3.5,
        "num_images":            1,
        "enable_safety_checker": True,
        "output_format":         "jpeg",
    }

    req_id = await fal_submit(FAL_FLUX_SUBMIT, payload)
    result = await fal_wait(FAL_FLUX_STATUS.format(req_id=req_id), label=f"FLUX-{scene_index}", max_sec=120)

    url = (
        (result.get("images") or [{}])[0].get("url")
        or result.get("image", {}).get("url")
        or ""
    )
    if not url:
        raise ValueError(f"Scene {scene_index}: FLUX ne image URL nahi diya. Response: {result}")

    print(f"    [Image] Scene {scene_index}: tayar ✓")
    return url


async def make_all_images(scenes: list) -> list:
    """Sab scenes ki images parallel mein banao (max 3 ek saath)"""
    semaphore = asyncio.Semaphore(3)

    async def limited(scene):
        async with semaphore:
            return await make_one_image(scene["image_prompt"], scene["index"])

    return list(await asyncio.gather(*[limited(s) for s in scenes]))


# ═══════════════════════════════════════════════════════════════════════════════
#  STEP 3 — VIDEO GENERATOR (Kling 2.6 Pro via fal.ai)
# ═══════════════════════════════════════════════════════════════════════════════

async def make_one_clip(scene: dict, image_url: str) -> str:
    """
    Image se 5-second video clip banao.
    Kling 2.6 Pro native audio (dialogue + ambient) khud generate karta hai.
    """
    idx = scene["index"]
    print(f"    [Video] Scene {idx}: Kling 2.6 Pro pe bhej raha hoon...")

    # Double quotes mein narration → Kling automatic lip sync + voice banata hai
    full_prompt = f'"{scene["narration_english"]}" {scene["animation_prompt"]}'

    payload = {
        "image_url":       image_url,
        "prompt":          full_prompt,
        "duration":        "5",
        "aspect_ratio":    "9:16",
        "negative_prompt": "blurry, static, distorted, watermark, ugly, low quality, no motion",
        "cfg_scale":       0.5,
        "enable_audio":    True,
    }

    req_id = await fal_submit(FAL_KLING_SUBMIT, payload)
    result = await fal_wait(FAL_KLING_STATUS.format(req_id=req_id), label=f"Kling-{idx}", max_sec=240)

    url = (
        result.get("video", {}).get("url")
        or (result.get("videos") or [{}])[0].get("url")
        or ""
    )
    if not url:
        raise ValueError(f"Scene {idx}: Kling ne video URL nahi diya. Response: {result}")

    print(f"    [Video] Scene {idx}: tayar ✓")
    return url


async def make_all_clips(scenes: list, image_urls: list) -> list:
    """Sab clips parallel mein banao (max 2 ek saath)"""
    semaphore = asyncio.Semaphore(2)

    async def limited(scene, img_url):
        async with semaphore:
            return await make_one_clip(scene, img_url)

    return list(await asyncio.gather(*[limited(s, u) for s, u in zip(scenes, image_urls)]))


# ═══════════════════════════════════════════════════════════════════════════════
#  STEP 4 — VIDEO ASSEMBLER (MiniMax Music + FFmpeg via fal.ai)
# ═══════════════════════════════════════════════════════════════════════════════

async def generate_music(music_mood: str) -> str:
    """MiniMax Music se category-matched background track banao"""
    prompt = f"{music_mood}, 60 seconds, smooth fade in and fade out, loopable, no sudden beats"
    print(f"    [Music] Generate ho raha hai...")

    req_id = await fal_submit(FAL_MUSIC_SUBMIT, {"prompt": prompt})
    result = await fal_wait(FAL_MUSIC_STATUS.format(req_id=req_id), label="Music", max_sec=120)

    url = result.get("audio", {}).get("url") or result.get("output", {}).get("url") or result.get("url", "")
    if not url:
        raise ValueError(f"MiniMax Music: URL nahi mila. Response: {result}")

    print("    [Music] tayar ✓")
    return url


async def merge_clips(clip_urls: list) -> str:
    """FFmpeg se sab clips ek video mein jodo"""
    print(f"    [Merge] {len(clip_urls)} clips jod raha hoon...")

    req_id = await fal_submit(FAL_MERGE_VID_SUBMIT, {"video_urls": clip_urls})
    result = await fal_wait(FAL_MERGE_VID_STATUS.format(req_id=req_id), label="Merge", max_sec=120)

    url = result.get("video", {}).get("url") or result.get("output", {}).get("url") or result.get("url", "")
    if not url:
        raise ValueError(f"FFmpeg merge: URL nahi mila. Response: {result}")

    print("    [Merge] tayar ✓")
    return url


async def mix_music_into_video(video_url: str, audio_url: str) -> str:
    """FFmpeg se background music 20% volume pe add karo"""
    print("    [Mix] Music add ho raha hai (20% volume)...")

    req_id = await fal_submit(FAL_MERGE_AUD_SUBMIT, {
        "video_url":    video_url,
        "audio_url":    audio_url,
        "audio_volume": 0.20,
    })
    result = await fal_wait(FAL_MERGE_AUD_STATUS.format(req_id=req_id), label="AudioMix", max_sec=120)

    url = result.get("video", {}).get("url") or result.get("output", {}).get("url") or result.get("url", "")
    if not url:
        raise ValueError(f"FFmpeg audio mix: URL nahi mila. Response: {result}")

    print("    [Mix] tayar ✓")
    return url


async def download_video(url: str, save_path: str) -> str:
    """Final video URL se local disk pe download karo"""
    print(f"    [Download] {save_path} pe save ho raha hai...")

    async with httpx.AsyncClient(timeout=180) as client:
        resp = await client.get(url)
        resp.raise_for_status()
        Path(save_path).write_bytes(resp.content)

    size_mb = Path(save_path).stat().st_size / 1_048_576
    print(f"    [Download] {size_mb:.1f} MB save hua ✓")
    return save_path


async def assemble_final_video(clip_urls: list, music_mood: str, output_path: str) -> str:
    """Music gen + clip merge parallel → phir audio mix → phir download"""
    print("\n  Step 4a: Music generate + clips merge (parallel)...")
    music_task = asyncio.create_task(generate_music(music_mood))
    merge_task = asyncio.create_task(merge_clips(clip_urls))
    music_url, merged_url = await asyncio.gather(music_task, merge_task)

    print("\n  Step 4b: Music video mein mix ho raha hai...")
    final_url = await mix_music_into_video(merged_url, music_url)

    print("\n  Step 4c: Final video download ho raha hai...")
    return await download_video(final_url, output_path)


# ═══════════════════════════════════════════════════════════════════════════════
#  STEP 5 — SOCIAL UPLOADER (upload-post.com)
# ═══════════════════════════════════════════════════════════════════════════════

def upload_to_social(video_path: str, title: str, description: str, tags: list, platforms: list) -> dict:
    """YouTube + TikTok + Instagram ek call mein upload karo"""
    key     = os.environ.get("UPLOAD_POST_API_KEY", "")
    profile = os.environ.get("UPLOAD_POST_PROFILE", "my-profile")

    if not key:
        print("\n  ⚠️  UPLOAD_POST_API_KEY nahi hai — upload skip ho gaya.")
        print("     Video output/ folder mein save hai. Manually upload kar saktay hain.")
        print("     Key: https://upload-post.com/dashboard\n")
        return {p: "skipped — API key nahi" for p in platforms}

    if not Path(video_path).exists():
        print(f"  ⚠️  Video file nahi mili: {video_path}")
        return {p: "skipped — file missing" for p in platforms}

    try:
        from upload_post import UploadPostClient
    except ImportError:
        print("  ⚠️  upload-post install nahi. Run: pip install upload-post")
        return {p: "skipped — package missing" for p in platforms}

    client = UploadPostClient(key)

    kwargs = {
        "title":         title[:100],
        "user":          profile,
        "platforms":     platforms,
        "first_comment": "Subscribe karo aur ❤️ zaroor karen!",
    }

    if "youtube" in platforms:
        kwargs["privacyStatus"]       = "public"
        kwargs["tags"]                = tags[:10]
        kwargs["youtube_title"]       = title[:100]
        kwargs["youtube_description"] = description
        kwargs["youtube_category_id"] = "22"

    if "tiktok" in platforms:
        kwargs["privacy_level"] = "PUBLIC_TO_EVERYONE"

    if "instagram" in platforms:
        kwargs["media_type"]      = "REELS"
        kwargs["instagram_title"] = title[:150]

    print(f"    Upload ho raha hai: {', '.join(p.upper() for p in platforms)}...")
    response = client.upload_video(video_path, **kwargs)

    results = {}
    if isinstance(response, dict) and response.get("success"):
        for p in platforms:
            pdata = response.get("results", {}).get(p, {})
            url   = pdata.get("url", "") if isinstance(pdata, dict) and pdata.get("success") else ""
            results[p] = url
            print(f"    {'✅' if url else '❌'} {p.upper():12}: {url or 'FAILED'}")
    else:
        err = response.get("message", str(response)) if isinstance(response, dict) else str(response)
        print(f"    ❌ Upload fail: {err}")
        results = {p: "" for p in platforms}

    return results


# ═══════════════════════════════════════════════════════════════════════════════
#  MAIN PIPELINE
# ═══════════════════════════════════════════════════════════════════════════════

async def run_pipeline(topic: str, category: str, platforms: list) -> dict:
    start_time = time.time()
    run_id     = datetime.now().strftime("%Y%m%d_%H%M%S")

    print(f"\n{'═'*54}")
    print(f"  Run ID   : {run_id}")
    print(f"  Topic    : {topic}")
    print(f"  Category : {category}")
    print(f"{'═'*54}\n")

    # ── Step 1: Script ────────────────────────────────────────
    print("► STEP 1/5  Script ban raha hai (Claude)...")
    script = generate_script(topic, category)
    script_path = OUTPUT_DIR / f"{run_id}_script.json"
    script_path.write_text(json.dumps(script, ensure_ascii=False, indent=2))
    print(f"  Script saved: {script_path}\n")

    # ── Step 2: Images ────────────────────────────────────────
    print("► STEP 2/5  3D Pixar images ban rahi hain (FLUX Pro, parallel)...")
    image_urls = await make_all_images(script["scenes"])
    print(f"  {len(image_urls)} images tayar ✓\n")

    # ── Step 3: Video clips ───────────────────────────────────
    print("► STEP 3/5  Video clips ban rahe hain (Kling 2.6 Pro, parallel)...")
    clip_urls = await make_all_clips(script["scenes"], image_urls)
    print(f"  {len(clip_urls)} clips tayar ✓\n")

    # ── Step 4: Assemble ──────────────────────────────────────
    print("► STEP 4/5  Final video assemble ho raha hai...")
    output_path = str(OUTPUT_DIR / f"{run_id}_final.mp4")
    final_video = await assemble_final_video(
        clip_urls   = clip_urls,
        music_mood  = script["music_mood"],
        output_path = output_path,
    )
    print(f"  Final video: {final_video} ✓\n")

    # ── Step 5: Upload ────────────────────────────────────────
    print("► STEP 5/5  Social media pe upload ho raha hai...")
    uploads = upload_to_social(
        video_path  = final_video,
        title       = script["title"],
        description = script["description"],
        tags        = script.get("tags", []),
        platforms   = platforms,
    )

    # ── Cost estimate ─────────────────────────────────────────
    n = len(script["scenes"])
    cost = round((n + 1) * 0.06 + n * 0.70 + 0.055, 2)
    elapsed = round(time.time() - start_time, 1)

    result = {
        "success":   True,
        "run_id":    run_id,
        "topic":     topic,
        "title":     script["title"],
        "video":     final_video,
        "script":    str(script_path),
        "uploads":   uploads,
        "time_sec":  elapsed,
        "cost_usd":  cost,
    }

    result_path = OUTPUT_DIR / f"{run_id}_result.json"
    result_path.write_text(json.dumps(result, ensure_ascii=False, indent=2))
    return result


# ═══════════════════════════════════════════════════════════════════════════════
#  UI — BANNER + INPUT
# ═══════════════════════════════════════════════════════════════════════════════

def print_banner():
    print("""
╔══════════════════════════════════════════════════════════╗
║       🎬  AI Viral Storyteller — 10/10 System           ║
║                                                          ║
║   Topic  →  Script  →  Pixar Video  →  Social Upload    ║
║                                                          ║
║   Engine: Claude + fal.ai + upload-post.com             ║
╚══════════════════════════════════════════════════════════╝
    """)


def check_keys():
    missing = []
    if not os.environ.get("FAL_AI_KEY"):
        missing.append("FAL_AI_KEY       → https://fal.ai/dashboard/keys")
    if not os.environ.get("ANTHROPIC_API_KEY"):
        missing.append("ANTHROPIC_API_KEY → https://console.anthropic.com/")
    if missing:
        print("❌  .env mein ye keys missing hain:\n")
        for m in missing:
            print(f"    {m}")
        print("\n    .env file banao aur keys add karo.")
        sys.exit(1)


def ask_inputs() -> tuple:
    print("📖  Story ka topic dein:\n")
    topic = input("    Topic: ").strip()
    if not topic:
        print("❌  Topic khali nahi ho sakta!")
        sys.exit(1)

    print("\n    Category chunein:")
    for i, c in enumerate(CATEGORIES, 1):
        print(f"      {i}. {c}")
    try:
        category = CATEGORIES[int(input("\n    Number (1-6): ").strip()) - 1]
    except (ValueError, IndexError):
        category = "Motivational"
    print(f"    → {category}")

    print("\n    Platform chunein:")
    for k, v in PLATFORM_OPTIONS.items():
        print(f"      {k}. {' + '.join(p.upper() for p in v)}")
    platforms = PLATFORM_OPTIONS.get(input("\n    Number (1-5): ").strip(), ["youtube", "tiktok", "instagram"])
    print(f"    → {', '.join(p.upper() for p in platforms)}")

    print(f"\n{'─'*54}")
    print(f"  Topic     : {topic}")
    print(f"  Category  : {category}")
    print(f"  Platforms : {', '.join(platforms)}")
    print(f"{'─'*54}")

    if input("\n  Start karein? (y/n): ").strip().lower() != "y":
        print("  Theek hai.")
        sys.exit(0)

    return topic, category, platforms


# ═══════════════════════════════════════════════════════════════════════════════
#  ENTRY POINT
# ═══════════════════════════════════════════════════════════════════════════════

async def main():
    print_banner()
    check_keys()

    parser = argparse.ArgumentParser()
    parser.add_argument("--topic",     default="")
    parser.add_argument("--category",  default="")
    parser.add_argument("--platforms", default="")
    args = parser.parse_args()

    if args.topic:
        topic     = args.topic
        category  = args.category if args.category in CATEGORIES else "Motivational"
        platforms = args.platforms.split(",") if args.platforms else ["youtube", "tiktok", "instagram"]
    else:
        topic, category, platforms = ask_inputs()

    try:
        result = await run_pipeline(topic, category, platforms)
    except KeyboardInterrupt:
        print("\n⚠️  Rok diya.")
        sys.exit(0)
    except Exception as e:
        print(f"\n❌  Error: {e}")
        raise

    print("\n" + "═" * 54)
    print("  ✅  VIDEO TAYAR HO GAYA!")
    print("═" * 54)
    print(f"  Title    : {result['title']}")
    print(f"  File     : {result['video']}")
    print(f"  Time     : {result['time_sec']}s")
    print(f"  Cost     : ~${result['cost_usd']} USD")
    print(f"\n  Uploads:")
    for p, url in result["uploads"].items():
        icon = "✅" if url and "skipped" not in url else "⚠️ "
        print(f"    {icon} {p.upper():14}: {url}")
    print(f"\n  Script   : {result['script']}")
    print("═" * 54 + "\n")


if __name__ == "__main__":
    asyncio.run(main())